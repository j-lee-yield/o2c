{
  "name": "@o2c/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "generate": "tsx src/client/generate.ts",
    "lint": "eslint src --ext .ts",
    "migrate": "tsx src/migrations/run.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@o2c/audit": "workspace:*",
    "@o2c/config": "workspace:*",
    "@o2c/contracts": "workspace:*",
    "@o2c/domain": "workspace:*",
    "@o2c/types": "workspace:*",
    "@o2c/workflows": "workspace:*"
  }
}
