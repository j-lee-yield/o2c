{
  "name": "@o2c/root",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean",
    "db:generate": "pnpm --filter @o2c/database generate",
    "db:migrate": "pnpm --filter @o2c/database migrate",
    "dev": "turbo run dev",
    "dev:api": "pnpm --filter @o2c/api dev",
    "dev:web": "pnpm --filter @o2c/web dev",
    "dev:worker": "pnpm --filter @o2c/worker dev",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "turbo": "^2.5.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
