    "@o2c/domain": "workspace:*",
    "@o2c/routing": "workspace:*",
    "@o2c/seed": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4"
  }
}
